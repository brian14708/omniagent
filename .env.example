# OmniAgent Phoenix/Postgres development settings.
# Load with: set -a; source .env; set +a
DATABASE_URL=postgresql://omniagent:omniagent@localhost:5432/omniagent
PGUSER=omniagent
PGPASSWORD=omniagent
PGHOST=localhost
PGPORT=5432
PGDATABASE=omniagent
POSTGRES_USER=omniagent
POSTGRES_PASSWORD=omniagent
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=omniagent
PGTESTDATABASE=omniagent_test
POSTGRES_TEST_DB=omniagent_test

# Seeded by apps/omniagent/priv/repo/seeds.exs for local CLI login.
OMNIAGENT_ADMIN_EMAIL=admin@omniagent.local
OMNIAGENT_DEV_TOKEN=dev-token
OMNIAGENT_SERVER_URL=http://127.0.0.1:4000
OMNIAGENT_API_TOKEN=dev-token

# Required for prod releases; harmless in dev if unused.
SECRET_KEY_BASE=change-me-generate-with-mix-phx-gen-secret
PORT=4000
POOL_SIZE=10
