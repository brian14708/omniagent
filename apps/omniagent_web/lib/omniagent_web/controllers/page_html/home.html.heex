<Layouts.flash_group flash={@flash} />

<header class="oa-topbar sticky top-0 z-40 px-6 py-3">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4">
    <a href={~p"/"} class="flex items-center gap-3">
      <img src={~p"/logo.svg"} alt="" class="oa-logo" />
      <Layouts.wordmark />
    </a>
    <div class="flex items-center gap-2.5">
      <%= if @logged_in do %>
        <.link navigate={~p"/console"} class="oa-btn primary">Open console</.link>
        <.link href={~p"/logout"} method="delete" class="oa-btn">Sign out</.link>
      <% else %>
        <.link href={~p"/login"} class="oa-btn primary">Sign in</.link>
      <% end %>
    </div>
  </div>
</header>

<main class="mx-auto max-w-6xl px-6 pb-24 pt-16 md:pt-24">
  <section class="oa-reveal max-w-3xl">
    <div class="oa-label mb-6">Orchestrate · Manage · Network · Inspect</div>
    <h1 class="oa-display text-[2.6rem] leading-[1.04] text-[var(--text)] md:text-[4rem]">
      Run every agent.<br />
      <span class="text-[var(--accent)]">Replay everything.</span>
    </h1>
    <p class="mt-7 max-w-xl text-[15px] leading-relaxed text-[var(--dim)]">
      OmniAgent runs your local coding agents — Claude, Codex, and more — and
      streams every terminal, LLM request, diff, and review into one console.
      Provider keys never leave your machine.
    </p>
    <div class="mt-9 flex flex-wrap items-center gap-3">
      <%= if @logged_in do %>
        <.link navigate={~p"/console"} class="oa-btn primary py-2.5 text-[12px]">
          Open console →
        </.link>
      <% else %>
        <.link href={~p"/login"} class="oa-btn primary py-2.5 text-[12px]">
          Sign in →
        </.link>
      <% end %>
    </div>
  </section>

  <section class="mt-20 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <%= for {letter, word, body} <- [
      {"O", "Orchestrate", "Run and coordinate any number of agent runtimes — Claude, Codex, more — each in its own session."},
      {"M", "Manage", "Act on runs as they happen: approve, retry, or reject at every review gate, and start or stop sessions."},
      {"N", "Network", "Share live instances and logs across machines. Multi-node by default — drive an agent from any node."},
      {"I", "Inspect", "Snapshot, replay, and compare any run — every LLM request, working-tree diff, and decision."}
    ] do %>
      <div class="oa-panel oa-reveal p-5">
        <div class="oa-omni">{letter}</div>
        <h3 class="oa-display mt-3 text-[15px] text-[var(--text)]">{word}</h3>
        <p class="mt-2 text-[13px] leading-relaxed text-[var(--dim)]">{body}</p>
      </div>
    <% end %>
  </section>

  <section class="oa-reveal mt-16 max-w-2xl">
    <div class="oa-label mb-3">Install</div>
    <pre class="oa-pre text-[12px]"><span class="text-[var(--faint)]">$ </span>curl -fsSL {url(~p"/install.sh")} | sh</pre>
    <p class="mt-3 text-[13px] leading-relaxed text-[var(--dim)]">
      Installs the <code class="text-[var(--accent)]">omniagent</code>
      CLI to <code>~/.local/bin</code>
      from the latest nightly build.
    </p>
  </section>

  <section class="oa-reveal mt-12 max-w-2xl">
    <div class="oa-label mb-3">Getting started</div>
    <ol class="space-y-5">
      <li>
        <p class="text-[13px] leading-relaxed text-[var(--dim)]">
          <span class="text-[var(--text)]">1. Run setup.</span> It saves your
          console credentials and allows the workspaces the daemon may run agents
          under — point it at <code class="text-[var(--accent)]">{url(~p"/")}</code>.
        </p>
        <pre class="oa-pre mt-2 text-[12px]"><span class="text-[var(--faint)]">$ </span>omniagent setup</pre>
      </li>
      <li>
        <p class="text-[13px] leading-relaxed text-[var(--dim)]">
          <span class="text-[var(--text)]">2. Start the daemon.</span> It connects
          out to this console and waits for sessions to spawn.
        </p>
        <pre class="oa-pre mt-2 text-[12px]"><span class="text-[var(--faint)]">$ </span>omniagent daemon</pre>
      </li>
      <li>
        <p class="text-[13px] leading-relaxed text-[var(--dim)]">
          <span class="text-[var(--text)]">3. Start a session</span> from the
          console — pick a workspace and an isolated git worktree, and terminal,
          trace, and review events stream over a single outbound WebSocket while
          provider keys never leave your machine.
        </p>
        <div class="mt-3">
          <%= if @logged_in do %>
            <.link navigate={~p"/console"} class="oa-btn primary py-2 text-[12px]">
              Open console →
            </.link>
          <% else %>
            <.link href={~p"/login"} class="oa-btn primary py-2 text-[12px]">
              Sign in →
            </.link>
          <% end %>
        </div>
      </li>
    </ol>
  </section>
</main>
