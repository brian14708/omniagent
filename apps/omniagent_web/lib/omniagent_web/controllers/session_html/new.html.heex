<Layouts.flash_group flash={@flash} />

<div class="flex min-h-screen items-center justify-center px-6 py-16">
  <div class="oa-reveal w-full max-w-[22rem]">
    <div class="mb-9 flex flex-col items-center gap-4 text-center">
      <img
        src={~p"/favicon.svg"}
        alt=""
        class="oa-logo"
        style="width:46px;height:46px;border-radius:13px;"
      />
      <div>
        <Layouts.wordmark style="font-size:19px" />
        <p class="mt-2.5 font-mono text-[10px] uppercase tracking-[0.32em] text-[var(--faint)]">
          agent observability
        </p>
      </div>
    </div>

    <form action={~p"/login"} method="post" class="oa-panel p-6">
      <input type="hidden" name="_csrf_token" value={get_csrf_token()} />
      <div class="flex flex-col gap-5">
        <label class="flex flex-col gap-2">
          <span class="oa-colhead">Username</span>
          <input
            name="username"
            autocomplete="username"
            autofocus
            required
            class="oa-input"
          />
        </label>
        <label class="flex flex-col gap-2">
          <span class="oa-colhead">Password</span>
          <input
            type="password"
            name="password"
            autocomplete="current-password"
            required
            class="oa-input"
          />
        </label>
        <button type="submit" class="oa-btn primary mt-1 justify-center py-2.5 text-[12px]">
          Sign in
        </button>
      </div>
    </form>

    <p class="mt-5 text-center font-mono text-[10px] tracking-wide text-[var(--faint)]">
      dev placeholder — <span class="text-[var(--dim)]">admin / admin</span>
    </p>
  </div>
</div>
