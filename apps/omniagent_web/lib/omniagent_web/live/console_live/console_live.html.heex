<div
  id="console"
  phx-hook="Prefs"
  style={"--left-w: #{@left_w}px; --right-w: #{@right_w}px; --term-basis: #{@term_pct}%"}
  class="oa-console flex h-screen overflow-hidden text-[var(--text)]"
>
  <%!-- ── Left: sessions sidebar ───────────────────────────────────────── --%>
  <.sidebar
    sessions={@sessions}
    session={@session}
    daemons={@daemons}
    oad_instances={@oad_instances}
    oad_workspaces={@oad_workspaces}
    sidebar_collapsed={@sidebar_collapsed}
    sessions_collapsed={@sessions_collapsed}
    current_user={@current_user}
  />

  <%= unless @sidebar_collapsed do %>
    <div
      id="gutter-left"
      phx-hook="Resize"
      data-axis="x"
      data-var="--left-w"
      data-prop="left_w"
      data-min="180"
      data-max="520"
      class="oa-gutter oa-gutter-x"
      title="Drag to resize"
    >
    </div>
  <% end %>

  <%!-- ── Middle: terminal + traces ────────────────────────────────────── --%>
  <main class="flex min-w-0 flex-1 flex-col bg-[var(--bg)]">
    <%= if @session do %>
      <.session_pane session={@session} />
    <% else %>
      <div class="flex flex-1 flex-col items-center justify-center gap-4 text-center">
        <img src={~p"/logo.svg"} alt="" class="oa-logo" style="width:48px;height:48px" />
        <div>
          <p class="oa-display text-lg font-bold">No session selected</p>
          <p class="mt-1 font-mono text-xs text-[var(--faint)]">
            pick a session on the left, or launch one from a workspace under
            <span class="text-[var(--dim)]">Workspaces</span>
          </p>
        </div>
      </div>
    <% end %>
  </main>

  <%= unless @right_collapsed do %>
    <div
      id="gutter-right"
      phx-hook="Resize"
      data-axis="x"
      data-var="--right-w"
      data-prop="right_w"
      data-invert="true"
      data-min="240"
      data-max="600"
      class="oa-gutter oa-gutter-x"
      title="Drag to resize"
    >
    </div>
  <% end %>

  <%!-- ── Right: Files / Reviews / Artifacts ───────────────────────────── --%>
  <aside class={[
    "flex flex-none flex-col border-l border-[var(--line)] bg-[var(--panel)]",
    @right_collapsed && "w-10",
    !@right_collapsed && "w-[var(--right-w)]"
  ]}>
    <%= if @right_collapsed do %>
      <button
        type="button"
        phx-click="toggle_right_panel"
        title="Expand panel"
        class="flex h-[41px] w-full flex-none items-center justify-center border-b border-[var(--line)] text-[var(--faint)] hover:text-[var(--text)]"
      >
        «
      </button>
    <% else %>
      <div class="flex flex-none items-center gap-1 border-b border-[var(--line)] px-2 py-2">
        <%= for {key, label} <- [{"files", "Files"}, {"reviews", "Reviews"}, {"artifacts", "Artifacts"}] do %>
          <button
            type="button"
            phx-click="select_tab"
            phx-value-tab={key}
            class={[
              "rounded-md px-3 py-1 font-mono text-xs transition-colors",
              @right_tab == key && "bg-[var(--accent-soft)] text-[var(--accent)]",
              @right_tab != key && "text-[var(--faint)] hover:text-[var(--dim)]"
            ]}
          >
            {label}
          </button>
        <% end %>
        <button
          type="button"
          phx-click="toggle_right_panel"
          title="Collapse panel"
          class="ml-auto flex-none px-2 text-[var(--faint)] hover:text-[var(--text)]"
        >
          »
        </button>
      </div>

      <div class="min-h-0 flex-1 overflow-y-auto p-3">
        <%= cond do %>
          <% is_nil(@session) -> %>
            <p class="font-mono text-xs text-[var(--faint)]">select a session</p>
          <% @right_tab == "files" -> %>
            <.files_tab
              changes={@changes}
              changes_error={@changes_error}
              changes_loading={@changes_loading}
            />
          <% @right_tab == "reviews" -> %>
            <.reviews_tab reviews={@reviews} auto_approve={@auto_approve} />
          <% @right_tab == "artifacts" -> %>
            <.artifacts_tab artifacts={@artifacts} session={@session} />
          <% true -> %>
        <% end %>
      </div>
    <% end %>
  </aside>
</div>

<%!-- ── Diff modal (a changed file's unified diff) ───────────────────── --%>
<%= if @diff_result do %>
  <.modal
    on_close="close_diff"
    overlay_class="bg-black/70"
    panel_class="flex max-h-[85vh] w-full max-w-4xl flex-col p-0"
  >
    <div class="flex flex-none items-center justify-between gap-2 border-b border-[var(--line)] px-4 py-2.5">
      <span class="truncate font-mono text-xs text-[var(--dim)]" title={@diff_result["path"]}>
        {@diff_result["path"]}
      </span>
      <button
        type="button"
        phx-click="close_diff"
        title="Close"
        class="flex-none px-1.5 text-[var(--faint)] hover:text-[var(--text)]"
      >
        ✕
      </button>
    </div>
    <div class="min-h-0 flex-1 overflow-auto p-4">
      <%= cond do %>
        <% @diff_result["loading"] -> %>
          <p class="font-mono text-xs text-[var(--faint)]">loading diff…</p>
        <% @diff_result["empty"] -> %>
          <p class="font-mono text-xs text-[var(--faint)]">no changes for this file</p>
        <% @diff_result["ok"] -> %>
          <%!-- Key the id by a hash of the diff text so an in-place refresh
               (same file, new content) forces a remount — phx-update="ignore"
               would otherwise leave the DiffHighlight hook showing stale text. --%>
          <div
            id={"diff-view-#{@diff_result["path"]}-#{:erlang.phash2(@diff_result["diff"])}"}
            phx-hook="DiffHighlight"
            phx-update="ignore"
            data-diff={@diff_result["diff"]}
            data-path={@diff_result["path"]}
            class="font-mono text-[11px] leading-[1.5]"
          >
          </div>
        <% true -> %>
          <p class="font-mono text-xs text-[var(--prov-red)]">{@diff_result["error"]}</p>
      <% end %>
    </div>
  </.modal>
<% end %>

<%!-- ── New-agent modal ──────────────────────────────────────────────── --%>
<%= if @modal == :new_agent do %>
  <.modal>
    <h2 class="oa-display mb-4 text-lg font-bold">New agent</h2>
    <%= if @daemons == [] do %>
      <p class="font-mono text-sm text-[var(--dim)]">
        No daemon is connected. Start one with <code class="text-[var(--accent)]">omniagent daemon</code>, then try again.
      </p>
      <div class="mt-4 flex justify-end">
        <button type="button" phx-click="close_modal" class="oa-btn">Close</button>
      </div>
    <% else %>
      <% sel_daemon = daemon_by_id(@daemons, @new_agent_daemon) || List.first(@daemons) %>
      <% workspaces = daemon_workspaces(sel_daemon) %>
      <% sel_ws = workspace_by_path(sel_daemon, @new_agent_workspace) || List.first(workspaces) %>
      <% git = workspace_git(sel_ws) %>
      <form phx-submit="create_agent" phx-change="new_agent_change" class="space-y-3">
        <input type="hidden" name="daemon_id" value={@new_agent_daemon} />
        <div class="rounded-md border border-[var(--line)] bg-[var(--panel-2)] px-3 py-2 font-mono text-[11px]">
          <div class="oa-label mb-0.5">Daemon</div>
          <div class="truncate text-[var(--dim)]">
            {sel_daemon && daemon_label(sel_daemon)}
            <span class="text-[var(--faint)]">· {sel_daemon && sel_daemon.metadata["cwd"]}</span>
          </div>
        </div>
        <input type="hidden" name="workspace" value={@new_agent_workspace} />
        <div class="rounded-md border border-[var(--line)] bg-[var(--panel-2)] px-3 py-2 font-mono text-[11px]">
          <div class="oa-label mb-0.5">Workspace</div>
          <div class="truncate text-[var(--dim)]" title={sel_ws && sel_ws["path"]}>
            {sel_ws && sel_ws["path"]}
            <%= if sel_ws do %>
              <span class="text-[var(--faint)]">· {sel_ws["kind"]}</span>
            <% end %>
          </div>
        </div>

        <%= if git do %>
          <fieldset class="space-y-2">
            <span class="oa-label">Worktree</span>
            <label class="flex items-center gap-2 font-mono text-[12px]">
              <input
                type="radio"
                name="worktree_mode"
                value="in_place"
                checked={@new_agent_mode not in ["existing", "create"]}
              />
              <span>
                In place
                <%= if git["current_branch"] do %>
                  <span class="text-[var(--faint)]">(on {git["current_branch"]})</span>
                <% end %>
              </span>
            </label>
            <label class="flex items-center gap-2 font-mono text-[12px]">
              <input
                type="radio"
                name="worktree_mode"
                value="create"
                checked={@new_agent_mode == "create"}
              />
              <span>New isolated worktree</span>
            </label>
            <%= if @new_agent_mode == "create" do %>
              <div class="ml-6 space-y-2">
                <input
                  name="branch"
                  class="oa-input w-full"
                  placeholder="new branch name (blank = auto)"
                />
                <select name="base_branch" class="oa-input w-full">
                  <option value="">base: {git["current_branch"] || "current HEAD"}</option>
                  <%= for b <- git["branches"] || [] do %>
                    <option value={b}>base: {b}</option>
                  <% end %>
                </select>
              </div>
            <% end %>
            <%= if (git["worktrees"] || []) != [] do %>
              <label class="flex items-center gap-2 font-mono text-[12px]">
                <input
                  type="radio"
                  name="worktree_mode"
                  value="existing"
                  checked={@new_agent_mode == "existing"}
                />
                <span>Use existing worktree</span>
              </label>
              <%= if @new_agent_mode == "existing" do %>
                <div class="ml-6">
                  <select name="worktree" class="oa-input w-full">
                    <%= for wt <- git["worktrees"] || [] do %>
                      <option value={wt["path"]}>
                        {wt["path"]}
                        <%= if wt["branch"] do %>
                          · {wt["branch"]}
                        <% end %>
                      </option>
                    <% end %>
                  </select>
                </div>
              <% end %>
            <% end %>
          </fieldset>
        <% end %>

        <label class="block">
          <span class="oa-label mb-1">Agent</span>
          <select name="agent" class="oa-input w-full">
            <option value="claude">claude</option>
            <option value="codex">codex (terminal)</option>
            <option value="codex-app-server">codex (app-server · native)</option>
            <option value="gemini">gemini</option>
          </select>
        </label>

        <.agent_meta_fields extra_placeholder="appended to the agent command, e.g. --model gpt-5" />
        <div class="flex justify-end gap-2 pt-2">
          <button type="button" phx-click="close_modal" class="oa-btn">Cancel</button>
          <button type="submit" class="oa-btn primary">Start agent</button>
        </div>
      </form>
    <% end %>
  </.modal>
<% end %>

<%!-- ── New-workspace modal ──────────────────────────────────────────── --%>
<%= if @modal == :new_workspace do %>
  <.modal>
    <h2 class="oa-display mb-4 text-lg font-bold">New workspace</h2>
    <%= if @daemons == [] do %>
      <p class="font-mono text-sm text-[var(--dim)]">
        No daemon is connected. Start one with <code class="text-[var(--accent)]">omniagent daemon</code>, then try again.
      </p>
      <div class="mt-4 flex justify-end">
        <button type="button" phx-click="close_modal" class="oa-btn">Close</button>
      </div>
    <% else %>
      <% ws_daemon = daemon_by_id(@daemons, @new_workspace_daemon) || List.first(@daemons) %>
      <form phx-submit="create_workspace" class="space-y-3">
        <input type="hidden" name="daemon_id" value={ws_daemon && ws_daemon.id} />
        <div class="rounded-md border border-[var(--line)] bg-[var(--panel-2)] px-3 py-2 font-mono text-[11px]">
          <div class="oa-label mb-0.5">Daemon</div>
          <div class="truncate text-[var(--dim)]">
            {ws_daemon && daemon_label(ws_daemon)}
            <span class="text-[var(--faint)]">· {ws_daemon && ws_daemon.metadata["cwd"]}</span>
          </div>
        </div>
        <label class="block">
          <span class="oa-label mb-1">Workspace name</span>
          <input
            name="name"
            class="oa-input w-full"
            placeholder="my-project"
            autocomplete="off"
            required
          />
          <span class="mt-1 block font-mono text-[11px] text-[var(--faint)]">
            Created as a git repo under the daemon's local data dir and added to its allowed workspaces.
          </span>
        </label>
        <div class="flex justify-end gap-2 pt-2">
          <button type="button" phx-click="close_modal" class="oa-btn">Cancel</button>
          <button type="submit" class="oa-btn primary">Create workspace</button>
        </div>
      </form>
    <% end %>
  </.modal>
<% end %>

<%= if @modal == :new_oad_workspace do %>
  <.modal panel_class="flex max-h-[85vh] w-full max-w-lg flex-col p-5">
    <h2 class="oa-display mb-4 text-lg font-bold">New oad workspace</h2>
    <form
      phx-submit="create_oad_workspace"
      phx-change="oad_ws_changed"
      class="flex min-h-0 flex-col space-y-3 overflow-y-auto"
    >
      <label class="block">
        <span class="oa-label mb-1">Name</span>
        <input
          name="name"
          class="oa-input w-full"
          placeholder="my-project"
          autocomplete="off"
          required
        />
      </label>
      <label class="block">
        <span class="oa-label mb-1">Image</span>
        <input
          name="image"
          class="oa-input w-full"
          placeholder="ghcr.io/org/devcontainer:latest"
          autocomplete="off"
          required
        />
      </label>
      <label class="block">
        <span class="oa-label mb-1">Repository (optional)</span>
        <input
          name="repo"
          class="oa-input w-full"
          placeholder="https://github.com/org/repo.git"
          autocomplete="off"
        />
      </label>
      <label class="block">
        <span class="oa-label mb-1">Ref (optional)</span>
        <input name="git_ref" class="oa-input w-full" placeholder="main" autocomplete="off" />
      </label>

      <%!-- Agents to install — toggling regenerates the install script below. --%>
      <div class="block">
        <span class="oa-label mb-1">Agents to install</span>
        <div class="flex flex-wrap gap-x-4 gap-y-1.5">
          <%= for key <- ~w(claude-code codex gemini) do %>
            <label class="flex items-center gap-1.5 font-mono text-[12px] text-[var(--dim)]">
              <input type="checkbox" name="agents[]" value={key} checked={key in @oad_ws_agents} />
              {key}
            </label>
          <% end %>
        </div>
      </div>

      <label class="block">
        <span class="oa-label mb-1">Install script</span>
        <textarea
          name="agent_install"
          rows="3"
          spellcheck="false"
          class="oa-input w-full font-mono text-[12px]"
        ><%= @oad_ws_install_script %></textarea>
        <span class="mt-1 block font-mono text-[11px] text-[var(--faint)]">
          Generated from the selected agents — edit freely (toggling an agent regenerates it).
        </span>
      </label>

      <label class="block">
        <span class="oa-label mb-1">LLM env (optional)</span>
        <textarea
          name="env"
          rows="3"
          spellcheck="false"
          class="oa-input w-full font-mono text-[12px]"
          placeholder="ANTHROPIC_API_KEY=sk-...&#10;OPENAI_BASE_URL=https://..."
        ></textarea>
        <span class="mt-1 block font-mono text-[11px] text-[var(--faint)]">
          One KEY=VALUE per line. Available at build time and to the running agent.
        </span>
      </label>

      <div class="grid grid-cols-2 gap-3">
        <label class="block">
          <span class="oa-label mb-1">CPU (cores, optional)</span>
          <input name="cpu" class="oa-input w-full" placeholder="2" autocomplete="off" />
        </label>
        <label class="block">
          <span class="oa-label mb-1">Memory (optional)</span>
          <input name="memory" class="oa-input w-full" placeholder="4Gi" autocomplete="off" />
        </label>
      </div>

      <span class="block font-mono text-[11px] text-[var(--faint)]">
        Built on a registered oad instance and snapshotted; sessions fork from the snapshot.
      </span>

      <div class="flex justify-end gap-2 pt-2">
        <button type="button" phx-click="close_modal" class="oa-btn">Cancel</button>
        <button type="submit" class="oa-btn primary">Build workspace</button>
      </div>
    </form>
  </.modal>
<% end %>

<%!-- ── oad build progress ───────────────────────────────────────────── --%>
<%= if @modal == :oad_build do %>
  <.modal panel_class="flex max-h-[80vh] w-full max-w-lg flex-col p-5">
    <div class="mb-3 flex items-center gap-2">
      <%= cond do %>
        <% @oad_build_status == "ready" -> %>
          <.icon name="hero-check-circle" class="size-5 flex-none text-[var(--prov-green)]" />
        <% @oad_build_status == "error" -> %>
          <.icon name="hero-x-circle" class="size-5 flex-none text-[var(--prov-red)]" />
        <% true -> %>
          <.icon
            name="hero-arrow-path"
            class="size-5 flex-none animate-spin text-[var(--accent)]"
          />
      <% end %>
      <h2 class="oa-display flex-1 truncate text-lg font-bold">
        Building {@oad_build_name}
      </h2>
      <span class="flex-none font-mono text-[11px] uppercase tracking-wide text-[var(--faint)]">
        {@oad_build_status}
      </span>
    </div>

    <%!-- flex-col-reverse + newest-first log keeps the view pinned to the
          latest line without a scroll hook. --%>
    <div class="flex min-h-0 flex-1 flex-col-reverse overflow-y-auto rounded bg-[var(--panel-2)] px-3 py-2 font-mono text-[12px] leading-relaxed text-[var(--dim)]">
      <%= for line <- @oad_build_log do %>
        <div class="whitespace-pre-wrap break-words">{line}</div>
      <% end %>
    </div>

    <%= if @oad_build_status == "error" do %>
      <p class="mt-3 font-mono text-[11px] text-[var(--prov-red)]">
        Build failed — see the log above.
      </p>
    <% end %>

    <div class="mt-4 flex justify-end gap-2">
      <button type="button" phx-click="close_modal" class="oa-btn">
        {if @oad_build_status == "building", do: "Hide", else: "Close"}
      </button>
    </div>
  </.modal>
<% end %>

<%!-- ── oad agent picker ─────────────────────────────────────────────── --%>
<%= if @modal == :oad_agent do %>
  <.modal>
    <h2 class="oa-display mb-4 text-lg font-bold">
      Run agent on {@oad_agent_workspace}
    </h2>
    <form phx-submit="start_oad_session" class="space-y-3">
      <input type="hidden" name="workspace" value={@oad_agent_workspace} />
      <label class="block">
        <span class="oa-label mb-1">Agent</span>
        <select name="agent" class="oa-input w-full">
          <option value="claude">claude</option>
          <option value="codex">codex</option>
          <option value="gemini">gemini</option>
        </select>
      </label>
      <.agent_meta_fields />
      <div class="flex justify-end gap-2 pt-2">
        <button type="button" phx-click="close_modal" class="oa-btn">Cancel</button>
        <button type="submit" class="oa-btn primary">Start agent</button>
      </div>
    </form>
  </.modal>
<% end %>

<%!-- ── Recording player ─────────────────────────────────────────────── --%>
<%= if @playing_artifact do %>
  <.modal
    on_close="close_recording"
    overlay_class="bg-black/70"
    panel_class="w-full max-w-4xl p-4"
  >
    <div class="mb-3 flex items-center justify-between">
      <h2 class="oa-display text-lg font-bold">Terminal recording</h2>
      <button type="button" phx-click="close_recording" class="oa-btn text-xs">Close</button>
    </div>
    <div
      id={"recording-#{@playing_artifact.id}"}
      phx-hook="Recording"
      phx-update="ignore"
      data-src={~p"/sessions/#{@session.id}/artifacts/#{@playing_artifact.id}/download"}
    >
    </div>
  </.modal>
<% end %>

<Layouts.flash_group flash={@flash} />
